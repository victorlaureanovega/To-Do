  >
    <div>
      DeveloperHours:
      all
    </div>
    <div>
      FinishedAvg:
      team
    </div>
    <div>
      WorkedAvg:
      team
    </div>
  </div>
  <div>
    KPI:
    100.0%
  </div>
  <div>
    <div
      class="analytics-grid__full-row"
    >
      <div>
        StatusChart:
        all
      </div>
    </div>
    <div
      class="analytics-grid__full-row"
    >
      <div>
        ByDate:
        1
      </div>
    </div>
    <div>
      Completion:
      2
    </div>
    <div>
      TaskType:
      1
    </div>
    <div>
      TimeChart:
      all
    </div>
  </div>
</div>
